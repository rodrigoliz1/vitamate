{
  "name": "vitamate-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "native:sync:ios": "tsc --noEmit && vite build && cap sync ios",
    "native:open:ios": "cap open ios",
    "native:run:ios": "tsc --noEmit && vite build && cap sync ios && cap run ios",
    "native:doctor": "cap doctor"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "8.0.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/barcode-scanner": "3.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/camera": "8.2.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.4.2",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/local-notifications": "8.2.0",
    "@capacitor/network": "8.0.1",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/push-notifications": "8.1.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@capgo/capacitor-health": "8.9.3",
    "@capgo/native-purchases": "8.6.4",
    "@ionic/react": "^7.7.4",
    "@ionic/react-router": "^7.7.4",
    "@supabase/supabase-js": "^2.49.4",
    "@vitamate/design-tokens": "workspace:*",
    "@vitamate/domain": "workspace:*",
    "@vitamate/ui": "workspace:*",
    "ionicons": "^7.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^9",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-router-dom": "^5.3.3",
    "@vitamate/config": "workspace:*",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^0.19.2"
  }
}
