{
  "appId": "mx.vitamate.app",
  "appName": "VITAMATE",
  "webDir": "dist",
  "backgroundColor": "#F8F6EF",
  "server": {
    "iosScheme": "https",
    "hostname": "app.vitamate.mx"
  },
  "ios": {
    "contentInset": "never",
    "allowsLinkPreview": false,
    "preferredContentMode": "mobile",
    "scrollEnabled": true
  },
  "plugins": {
    "Keyboard": {
      "resize": "native",
      "style": "light",
      "resizeOnFullScreen": true
    },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#F8F6EFFF",
      "showSpinner": false
    },
    "StatusBar": {
      "overlaysWebView": false,
      "style": "light",
      "backgroundColor": "#F8F6EF"
    },
    "LocalNotifications": {
      "presentationOptions": ["badge", "sound", "banner", "list"]
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "banner", "list"]
    }
  }
}
